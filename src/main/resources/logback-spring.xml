<configuration>
    <springProfile name="gui">
        <appender name="UserInterface" class="com.longx.intelligent.app.imessage.server.handler.UserInterfaceLogAppender"/>

        <appender name="GuiFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/gui.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- 按天切割 -->
                <fileNamePattern>logs/gui.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} : %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="UserInterface"/>
            <appender-ref ref="GuiFile"/>
        </root>
    </springProfile>

    <springProfile name="cli">
        <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} : %msg%n</pattern>
            </encoder>
        </appender>

        <appender name="CliFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/cli.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/cli.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} : %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="Console"/>
            <appender-ref ref="CliFile"/>
        </root>
    </springProfile>
</configuration>